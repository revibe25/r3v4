# ── App ───────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/r3

# ── File Uploads ──────────────────────────────
MAX_UPLOAD_SIZE_MB=50
MULTIPART_THRESHOLD_MB=10

# ── Signed URLs ───────────────────────────────
SIGNED_URL_EXPIRES=3600

# ── Stripe ────────────────────────────────────
# Use STRIPE_SECRET_KEY (STRIPE_SECRET is a legacy alias — consolidate to one)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
LOG_LEVEL=info

# ── Cloudflare R2 Storage ──────────────────────────────
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=r3-samples

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=info
