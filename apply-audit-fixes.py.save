!/usr/bin/env bash
# R3 AUDIT — Full file cat with headers
# Run from project root: bash cat-audit.sh > audit-dump.txt 2>&1

DIVIDER="================================================================"

cat_file() {
  local f="$1"
  echo ""
  echo "$DIVIDER"
  echo "FILE: $f"
  echo "$DIVIDER"
  if [ -f "$f" ]; then
    cat "$f"
  else
    echo "[NOT FOUND]"
  fi
}

cat_dir() {
  local d="$1"
  local ext="${2:-ts,tsx,js,mjs,json}"
  echo ""
  echo "$DIVIDER"
  echo "DIRECTORY: $d"
  echo "$DIVIDER"
  if [ -d "$d" ]; then
    find "$d" -type f | grep -E "\.(${ext//,/|})$" | sort | while read -r f; do
      cat_file "$f"
    done
  else
    echo "[NOT FOUND]"
  fi
}

# ── LLPTE PACKAGES ────────────────────────────────────────────────
for pkg in llpte-core llpte-signal llpte-transition-graph llpte-adapters llpte-execution llpte-ai; do
  cat_dir "packages/$pkg"
done

# ── SHARED / DATA CONTRACT ────────────────────────────────────────
cat_file "shared/schema.ts"
cat_file "shared/types.ts"
cat_file "shared/schema-subscription.ts"
cat_file "shared/audio.types.ts"
cat_file "shared/dj.types.ts"
cat_file "shared/mixer.types.ts"
cat_file "shared/effects.types.ts"
cat_file "shared/waveform.types.ts"
cat_file "shared/subscription.types.ts"
cat_file "shared/index.ts"

# ── SERVER ────────────────────────────────────────────────────────
cat_file "server/routes.ts"
cat_file "server/trpc.ts"
cat_file "server/procedures.ts"
cat_file "server/config.ts"
cat_file "server/static.ts"
cat_file "server/storage.ts"
cat_dir  "server/routes"
cat_dir  "server/routers"
cat_dir  "server/server"
cat_dir  "server/agent"
cat_dir  "server/middleware"
cat_dir  "server/services"
cat_dir  "server/db"
cat_dir  "server/lib"
cat_dir  "server/utils"
cat_dir  "server/types"
cat_dir  "server/tools"

# ── SERVICES ──────────────────────────────────────────────────────
cat_dir "services/ai-mix"

# ── AUDIO ENGINE ──────────────────────────────────────────────────
cat_file "fx-chain.ts"
cat_file "crossfade.test.ts"
cat_dir  "src/engine"
cat_dir  "src/visual"

# ── CLIENT SRC ────────────────────────────────────────────────────
cat_dir  "client/src"

# ── ROOT ARTIFACTS ────────────────────────────────────────────────
cat_file "App.tsx"
cat_file "analyzer.ts"
cat_file "vst-master-panel.tsx"
cat_file "index.ts"
cat_file "tsconfig.json"
cat_file "package.json"
cat_file "pnpm-workspace.yaml"
cat_file "turbo.json"
cat_file "drizzle.config.ts"

# ── WORKLETS (anywhere in project) ───────────────────────────────
echo ""
echo "$DIVIDER"
echo "WORKLETS (all *.worklet.ts files)"
echo "$DIVIDER"
find . -name "*.worklet.ts" -not -path "*/node_modules/*" | sort | while read -r f; do
  cat_file "$f"
done

# ── DUPLICATE DETECTION ───────────────────────────────────────────
echo ""
echo "$DIVIDER"
echo "DUPLICATE .ts/.js FILENAME COLLISIONS"
echo "$DIVIDER"
find . -not -path "*/node_modules/*" -not -path "*/.git/*" -name "*.js" \
  | sed 's/\.js$//' | sort > /tmp/r3_js.txt
find . -not -path "*/node_modules/*" -not -path "*/.git/*" -name "*.ts" \
  | sed 's/\.ts$//' | sort > /tmp/r3_ts.txt
comm -12 /tmp/r3_js.txt /tmp/r3_ts.txt

# ── BAK FILES ─────────────────────────────────────────────────────
echo ""
echo "$DIVIDER"
echo "ALL .bak FILES"
echo "$DIVIDER"
find . -not -path "*/node_modules/*" -name "*.bak*" | sort

# ── SHELL SCRIPTS AT ROOT ─────────────────────────────────────────
echo ""
echo "$DIVIDER"
echo "ROOT-LEVEL SHELL SCRIPTS"
echo "$DIVIDER"
find . -maxdepth 1 -name "*.sh" | sort | while read -r f; do
  cat_file "$f"
done

echo ""
echo "$DIVIDER"
echo "AUDIT CAT COMPLETE"
echo "$DIVIDER"
