{
  "include": [
    "index.ts",
    "server/**/*",
    "shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "**/*.test.ts",
    "client/**/*",
    "shared/dist",
    "scripts/seed",
    "**/seed/**",
    "../vite.config.ts",
    "vite.config.ts"
  ],
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": [
      "node"
    ],
    "paths": {
      "@llpte/llpte-signal": [
        "./packages/llpte-signal/src/index.ts"
      ],
      "@shared/*": [
        "./shared/*"
      ]
    }
  },
  "ts-node": {
    "esm": true,
    "experimentalEsm": true,
    "compilerResolver": true
  }
}