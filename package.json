{
  "name": "@r3vibe/server",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n server,client -c blue,green \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "NODE_OPTIONS='--import dotenv/config' tsx watch --ignore ./client --ignore ./node_modules index.ts",
    "dev:client": "wait-on tcp:3000 && pnpm --filter @r3vibe/client dev",
    "build": "tsc",
    "start": "npx tsx index.ts",
    "seed": "tsx scripts/seed/index.ts",
    "lint:tokens": "tsx scripts/lint-design-tokens.ts",
    "lint": "eslint . && npm run lint:tokens",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "test:coverage": "vitest run --coverage",
    "implement-metrics": "tsx implement-session-metrics.ts",
    "verify": "pnpm tsc -p tsconfig.json --noEmit && pnpm tsc -p client/tsconfig.json --noEmit && pnpm tsc -p client/tsconfig.worklet.json --noEmit && pnpm tsc -p client/tsconfig.vocalspectra.json --noEmit",
    "verify:client": "pnpm tsc -p client/tsconfig.json --noEmit",
    "migrate": "cd server && npx drizzle-kit push --config drizzle.config.ts --force"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@trpc/server": "11.12.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "0.45.2",
    "drizzle-zod": "^0.7.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "postgres": "3.4.9",
    "stripe": "^20.4.1",
    "superjson": "^2.2.6",
    "uuid": "^14.0.0",
    "ws": "^8.20.0",
    "zod": "^3.25.76",
    "zod-validation-error": "^3.5.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-rate-limit": "^5.1.3",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.18",
    "@types/pg": "^8.20.0",
    "@types/qs": "^6.15.1",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "3.2.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "esbuild": "0.25.12",
    "eslint": "^9.39.4",
    "eslint-formatter-unix": "^9.0.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "nanoid": "^5.1.11",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "ts-morph": "^27.0.2",
    "tsx": "^4.21.0",
    "turbo": "^2.9.12",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.6"
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "@smithy/types": "4.13.1",
      "drizzle-orm": "0.45.2",
      "postgres": "3.4.9",
      "picomatch": ">=4.0.4",
      "esbuild": "0.25.12",
      "vite": ">=6.4.2"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
