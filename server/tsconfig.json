{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@shared/*": [
        "../shared/*"
      ],
      "multer-s3": [
        "./types/multer-s3.d.ts"
      ]
    }
  },
  "include": [
    "./**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "scripts/seed",
    "**/seed/**",
    "../vite.config.ts",
    "../client/**",
    "vite-dev.ts",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
