{
  "name": "@r3vibe/server",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "R3VIBE Native - Backend API Server",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch index.ts",
    "build": "tsx ../script/build-server.ts",
    "start": "NODE_ENV=production node dist/index.cjs",
    "check": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx db/seed.ts"
  },
  "dependencies": {
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "pg": "^8.16.3",
    "connect-pg-simple": "^10.0.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0",
    "multer": "^2.0.2",
    "ws": "^8.18.0",
    "uuid": "^10.0.0",
    "mime-types": "^2.1.35",
    "helmet": "^8.0.0",
    "compression": "^1.7.5",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/passport": "^1.0.16",
    "@types/passport-local": "^1.0.38",
    "@types/node": "^20.16.11",
    "@types/ws": "^8.5.13",
    "@types/multer": "^1.4.12",
    "@types/uuid": "^10.0.0",
    "@types/mime-types": "^2.1.4",
    "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9",
    "@types/cors": "^2.8.17",
    "@types/connect-pg-simple": "^7.0.3",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.5",
    "typescript": "^5.6.3"
  }
}