# .env.example for R3vibe stack
# Copy to .env and fill in actual secrets for your environment.

# PostgreSQL database connection (LOCAL by default)
DATABASE_URL=postgresql://r3:YOUR_DB_PASSWORD@localhost:5432/r3vibe

# Disable SSL for local
DATABASE_SSL=false

# Session/cookie/jwt secrets (regenerate for prod)
INTERNAL_SECRET=CHANGEME_supersecret_for_jwt_and_sessions

# (Optional) OAuth or 3rd party keys (Google, etc)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Vite will expose vars prefixed with VITE_
# VITE_API_URL=http://localhost:3000

# Note: do not check your actual .env into public repos!