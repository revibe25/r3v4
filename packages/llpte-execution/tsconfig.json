{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@shared/*": ["../../shared/*"],
      "@llpte/*": ["../*"]
    }
  },
  "references": [
    { "path": "../../shared" },
    { "path": "../llpte-signal" },
    { "path": "../llpte-core" },
    { "path": "../llpte-adapters" },
    { "path": "../llpte-transition-graph" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
