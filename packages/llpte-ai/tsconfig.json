{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@shared/*": ["./shared/*"],
      "@llpte/llpte-signal": ["./packages/llpte-signal/dist/index"]
    }
  },
  "references": [
    { "path": "../../shared" },
    { "path": "../llpte-signal" },
    { "path": "../llpte-core" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
