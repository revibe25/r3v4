{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "webworker",
      "ESNext"
    ],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "noImplicitAny": false
  },
  "include": [
    "src/audio/fx/vst-processor.worklet.ts",
    "src/audio/recorder/recorder-worklet.ts",
    "src/worklets/instrument-processor.worklet.ts"
  ]
}
