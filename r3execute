# SUMMARY
# ============================================================================
echo ""
echo "${BLD}${CYN}════════════════════════════════════════════════════════${RST}"
echo "${BLD}${CYN}  AUDIT COMPLETE${RST}"
echo "${BLD}${CYN}════════════════════════════════════════════════════════${RST}"
echo ""

TOTAL=$((FAILURES + WARNINGS))

if [[ "$FAILURES" -eq 0 && "$WARNINGS" -eq 0 ]]; then
  echo "${GRN}${BLD}  ✓ All checks passed. Project matches directive.${RST}"
elif [[ "$FAILURES" -eq 0 ]]; then
  echo "${YLW}${BLD}  ⚠  0 failures · $WARNINGS warning(s)${RST}"
  echo "${YLW}     Resolve warnings before production deploy.${RST}"
else
  echo "${RED}${BLD}  ✗  $FAILURES failure(s) · $WARNINGS warning(s)${RST}"
  echo "${RED}     Fix all failures before deploy.${RST}"
fi

echo ""
echo "${DIM}  Quick reference:${RST}"
echo "${DIM}    bash r3execute           — audit only (from project root)${RST}"
echo "${DIM}    bash r3execute . --clean — audit + auto-remove dead .bak files${RST}"
echo "${DIM}    r3audit \"task\"           — AI-powered directive task runner${RST}"
echo ""

exit $FAILURES
