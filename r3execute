#!/usr/bin/env bash
# ============================================================================
#  r3execute — R3 v4 Directive Execution & Audit Runner
#  Audits current project state against the R3 v4 Engineering Directive.
#  Executes safe automated fixes (e.g. maxHeight destructure, dead files).
#
#  Usage:
#    bash r3execute           — audit only
#    bash r3execute . --clean — audit + remove dead .bak files
# ============================================================================
set -euo pipefail

GRN=$'\033[0;32m'; RED=$'\033[0;31m'; YLW=$'\033[0;33m'
CYN=$'\033[0;36m'; BLD=$'\033[1m'; DIM=$'\033[2m'; RST=$'\033[0m'

ok()      { echo "${GRN}✓${RST} $*"; }
fail()    { echo "${RED}✗${RST} $*"; FAILURES=$((FAILURES+1)); }
warn()    { echo "${YLW}⚠${RST}  $*"; WARNINGS=$((WARNINGS+1)); }
info()    { echo "${CYN}→${RST} $*"; }
fixed()   { echo "${GRN}⚡${RST} AUTO-FIXED: $*"; }
section() {
  echo ""
  echo "${BLD}${CYN}── $* ──────────────────────────────────────${RST}"
}

FAILURES=0
WARNINGS=0
ROOT="${1:-$PWD}"
DB_URL="postgresql://r3:r3vibe@localhost:5432/r3vibe"

echo ""
echo "${BLD}${CYN}╔══════════════════════════════════════════════════════╗${RST}"
echo "${BLD}${CYN}║  R3 v4 · Directive Execution & Audit Runner         ║${RST}"
echo "${BLD}${CYN}╚══════════════════════════════════════════════════════╝${RST}"
echo "${DIM}  Root   : $ROOT${RST}"
echo "${DIM}  DB     : $DB_URL${RST}"
echo "${DIM}  Mode   : ${2:-audit only}${RST}"
echo ""

# ── Helper: check a key exists and isn't a placeholder ──────────────────────
check_env() {
  local file="$1" key="$2"
  if [[ ! -f "$file" ]]; then
    fail "$key — file not found: $file"
    return
  fi
  if grep -q "^${key}=" "$file" 2>/dev/null; then
    local val
    val=$(grep "^${key}=" "$file" | cut -d= -f2-)
    if [[ -z "$val" ]] \
    || [[ "$val" == *"your_"* ]] \
    || [[ "$val" == *"replace"* ]] \
    || [[ "$val" == "supersecret" ]] \
    || [[ "$val" == *"example"* ]]; then
      warn "$key has placeholder/weak value in $(basename "$file")"
    else
      ok "$key present in $(basename "$file")"
    fi
  else
    fail "$key MISSING from $(basename "$file")"
  fi
}

# ── Helper: grep check with explicit ok/fail (avoids && ok || fail pitfall) ──
grep_check() {
  local file="$1" pattern="$2" ok_msg="$3" fail_msg="$4"
  if [[ ! -f "$file" ]]; then
    fail "$fail_msg (file not found: $(basename "$file"))"
    return
  fi
  if grep -q "$pattern" "$file" 2>/dev/null; then
    ok "$ok_msg"
  else
    fail "$fail_msg"
  fi
}

# ============================================================================
# SECTION 1 — ENVIRONMENT CONTRACT
# ============================================================================
section "1. Environment Contract"

info "Checking server/.env..."
for key in JWT_SECRET DATABASE_URL SESSION_SECRET; do
  check_env "$ROOT/server/.env" "$key"
done

info "Checking root .env..."
for key in STRIPE_SECRET_KEY STRIPE_WEBHOOK_SECRET DATABASE_URL SESSION_SECRET; do
  check_env "$ROOT/.env" "$key"
done

