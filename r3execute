# ============================================================================
# SECTION 3 — DATABASE & SUBSCRIPTION
# ============================================================================
section "3. Database & Subscription"

info "Testing PostgreSQL connection..."
if psql "$DB_URL" -c "SELECT 1;" &>/dev/null 2>&1; then
  ok "PostgreSQL connection successful"

  # User existence
  USER_EXISTS=$(psql "$DB_URL" -t \
    -c "SELECT COUNT(*) FROM users WHERE username='testuser';" \
    2>/dev/null | tr -d '[:space:]' || echo 0)
  if [[ "$USER_EXISTS" -eq 1 ]]; then
    ok "User 'testuser' exists"
  else
    fail "User 'testuser' NOT found in DB"
  fi

  # Tier check
  TIER_VAL=$(psql "$DB_URL" -t \
    -c "SELECT tier FROM users WHERE username='testuser';" \
    2>/dev/null | tr -d '[:space:]' || echo "")
  if [[ "$TIER_VAL" == "pro_artist" ]]; then
    ok "User tier: pro_artist"
  else
    warn "User tier: '${TIER_VAL:-empty}' — expected pro_artist"
  fi

  # Email check
  EMAIL_VAL=$(psql "$DB_URL" -t \
    -c "SELECT COALESCE(email,'NULL') FROM users WHERE username='testuser';" \
    2>/dev/null | tr -d '[:space:]' || echo "NULL")
  if [[ "$EMAIL_VAL" == "NULL" || -z "$EMAIL_VAL" ]]; then
    fail "User email is NULL — email-based login will fail"
  else
    ok "User email set: $EMAIL_VAL"
  fi

  # Subscription record
  SUB_TIER=$(psql "$DB_URL" -t \
    -c "SELECT tier FROM subscriptions \
        WHERE user_id=(SELECT id FROM users WHERE username='testuser') \
        LIMIT 1;" \
    2>/dev/null | tr -d '[:space:]' || echo "")
  if [[ -n "$SUB_TIER" ]]; then
    ok "Subscription record exists: tier=$SUB_TIER"
  else
    fail "No subscription record for testuser — checkout/gating will fail"
  fi

  # Check stripe_events table exists (idempotency guard)
  EVENTS_TABLE=$(psql "$DB_URL" -t \
    -c "SELECT COUNT(*) FROM information_schema.tables \
        WHERE table_name='stripe_events';" \
    2>/dev/null | tr -d '[:space:]' || echo 0)
  if [[ "$EVENTS_TABLE" -ge 1 ]]; then
    ok "stripe_events table present (webhook idempotency guard)"
  else
    warn "stripe_events table missing — webhook idempotency guard absent"
  fi

else
  warn "Cannot connect to PostgreSQL — skipping all DB checks"
  warn "Ensure server is running and DB_URL is correct"
fi

# ============================================================================
# SECTION 4 — DEAD FILE CLEANUP
# ============================================================================
section "4. Dead File Cleanup"

BAK_FILES=$(find "$ROOT" \
  -not -path "*/node_modules/*" \
  -not -path "*/.git/*" \
  \( -name "*.bak*" -o -name "*.save" -o -name "*.archived*" -o -name "*-backup" \) \
  2>/dev/null || true)

if [[ -z "$BAK_FILES" ]]; then
  ok "No dead backup files found"
else
  warn "Dead backup files present ($(echo "$BAK_FILES" | grep -c . || echo 0) files):"
  echo "$BAK_FILES" | while IFS= read -r f; do
    [[ -n "$f" ]] && echo "  ${YLW}→${RST} $f"
  done
  if [[ "${2:-}" == "--clean" ]]; then
    echo "$BAK_FILES" | while IFS= read -r f; do
      [[ -n "$f" ]] && rm -v "$f" && fixed "Removed: $f"
    done
  else
    info "Run with --clean to auto-remove"
  fi
fi

