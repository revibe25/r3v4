section "5. LLPTE Package Boundaries"

PKGS_DIR="$ROOT/packages"
if [[ -d "$PKGS_DIR" ]]; then

  # All 6 packages must exist
  for pkg in llpte-core llpte-signal llpte-transition-graph \
              llpte-execution llpte-ai llpte-adapters; do
    if [[ -d "$PKGS_DIR/$pkg" ]]; then
      ok "Package present: $pkg"
    else
      fail "Package MISSING: $pkg"
    fi
  done

  # llpte-core must have zero upward deps
  CORE_PKG="$PKGS_DIR/llpte-core/package.json"
  if [[ -f "$CORE_PKG" ]]; then
    UPWARD=$(grep -cE "llpte-ai|llpte-adapters|llpte-execution|llpte-signal" \
      "$CORE_PKG" 2>/dev/null || true)
    if [[ "$UPWARD" -eq 0 ]]; then
      ok "llpte-core: zero upward LLPTE dependencies"
    else
      fail "llpte-core has $UPWARD upward LLPTE dep(s) — architectural violation"
    fi
  else
    warn "llpte-core/package.json not found — cannot verify boundary"
  fi

  # llpte-adapters must not be imported by other LLPTE packages
  ADAPTERS_IN_CORE=$(grep -rn "llpte-adapters" \
    "$PKGS_DIR/llpte-core" \
    "$PKGS_DIR/llpte-signal" \
    "$PKGS_DIR/llpte-execution" \
    "$PKGS_DIR/llpte-ai" \
    --include="*.ts" 2>/dev/null | wc -l | tr -d '[:space:]' || echo 0)
  if [[ "$ADAPTERS_IN_CORE" -eq 0 ]]; then
    ok "llpte-adapters not imported by inner packages"
  else
    fail "llpte-adapters imported by inner packages ($ADAPTERS_IN_CORE occurrences) — violation"
  fi

else
  warn "packages/ directory not found — skipping LLPTE boundary checks"
fi

# ============================================================================
# SECTION 6 — PANEL SCROLL WIRING
# ============================================================================
section "6. Panel Scroll Wiring"

INST="$ROOT/client/src/pages/instrument.tsx"
if [[ ! -f "$INST" ]]; then
  fail "instrument.tsx not found"
else
  # scrollable prop in render calls (expect 2 — one per column map)
  SCROLLABLE_COUNT=$(grep -c "scrollable={true}" "$INST" 2>/dev/null || echo 0)
  if [[ "$SCROLLABLE_COUNT" -ge 2 ]]; then
    ok "scrollable={true} wired in both column map renders ($SCROLLABLE_COUNT)"
  else
    fail "scrollable={true} only in $SCROLLABLE_COUNT render call(s) — expected 2"
  fi

  # maxHeight in panel objects (expect >=9 — one per panel)
  MAXHEIGHT_OBJ=$(grep -c "maxHeight:" "$INST" 2>/dev/null || echo 0)
  if [[ "$MAXHEIGHT_OBJ" -ge 9 ]]; then
    ok "maxHeight defined on all panels ($MAXHEIGHT_OBJ objects)"
  else
    fail "maxHeight only on $MAXHEIGHT_OBJ panel object(s) — expected >=9"
  fi

  # .ag-panel-scroll CSS block
  CSS_COUNT=$(grep -c "ag-panel-scroll" "$INST" 2>/dev/null || echo 0)
  if [[ "$CSS_COUNT" -ge 1 ]]; then
    ok ".ag-panel-scroll CSS present ($CSS_COUNT rule(s))"
  else
    fail ".ag-panel-scroll CSS missing — scrollbar styling absent"
  fi

  # maxHeight destructured in map calls (expect 2)
  DESTR_COUNT=$(grep -c "num, title, icon, open, body, maxHeight" "$INST" 2>/dev/null || echo 0)
  if [[ "$DESTR_COUNT" -ge 2 ]]; then
    ok "maxHeight destructured in both map calls"
  else
    fail "maxHeight NOT destructured in map calls ($DESTR_COUNT/2) — ReferenceError at runtime"
    warn "Auto-fixing maxHeight destructure..."
    sed -i \
      's|].map(({ num, title, icon, open, body })|].map(({ num, title, icon, open, body, maxHeight })|g' \
      "$INST"
    DESTR_AFTER=$(grep -c "num, title, icon, open, body, maxHeight" "$INST" 2>/dev/null || echo 0)
    if [[ "$DESTR_AFTER" -ge 2 ]]; then
      fixed "maxHeight destructure fixed ($DESTR_AFTER/2 maps updated)"
    else
      fail "Auto-fix failed — inspect instrument.tsx map destructures manually"
    fi
  fi
fi

