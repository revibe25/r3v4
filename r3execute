    "isAuthenticated missing from ProtectedRoute — auth guard broken"
fi

# ============================================================================
# SECTION 14 — DEPLOYMENT READINESS
# ============================================================================
section "14. Deployment Readiness"

VERCEL_JSON="$ROOT/client/vercel.json"
if [[ ! -f "$VERCEL_JSON" ]]; then
  warn "client/vercel.json not found — Vercel routing unconfigured"
else
  if grep -qiE "placeholder|your-app\.railway|example\.com|REPLACE" \
      "$VERCEL_JSON" 2>/dev/null; then
    warn "client/vercel.json has Railway domain placeholder — update before deploy"
    info "Set to your actual Railway app URL before running: vercel --prod"
  else
    ok "client/vercel.json appears configured"
  fi
fi

[[ -f "$ROOT/railway.toml" ]] \
  && ok "railway.toml present" \
  || warn "railway.toml not found"

[[ -f "$ROOT/Dockerfile" ]] \
  && ok "Dockerfile present" \
  || warn "Dockerfile not found"

[[ -f "$ROOT/docker-compose.yml" ]] \
  && ok "docker-compose.yml present" \
  || warn "docker-compose.yml not found"

# Check Stripe live keys haven't been rotated
LIVE_KEY=$(grep "^STRIPE_SECRET_KEY=sk_live_" "$ROOT/server/.env" \
  "$ROOT/.env" 2>/dev/null | head -1 || echo "")
if [[ -n "$LIVE_KEY" ]]; then
  fail "LIVE Stripe key still in plaintext .env file — ROTATE IMMEDIATELY in Stripe dashboard"
  warn "Log into Stripe → Developers → API Keys → Roll secret key"
else
  ok "Stripe live key not exposed in plaintext env files"
fi

