  ok "JWT_SECRET length: ${#JWT_VAL} chars (>=64 required)"
else
  fail "JWT_SECRET too short: ${#JWT_VAL} chars — need >=64"
fi

# SESSION_SECRET strength check
SESSION_VAL=$(grep "^SESSION_SECRET=" "$ROOT/server/.env" 2>/dev/null | cut -d= -f2- || echo "")
if [[ "$SESSION_VAL" == "supersecret" ]]; then
  fail "SESSION_SECRET is 'supersecret' — CRITICAL SECURITY RISK"
elif [[ ${#SESSION_VAL} -ge 64 ]]; then
  ok "SESSION_SECRET hardened (${#SESSION_VAL} chars)"
elif [[ ${#SESSION_VAL} -ge 32 ]]; then
  ok "SESSION_SECRET adequate (${#SESSION_VAL} chars)"
else
  warn "SESSION_SECRET weak (${#SESSION_VAL} chars — recommend >=64)"
fi

# Startup validation guard in server/config.ts
grep_check \
  "$ROOT/server/config.ts" \
  "JWT_SECRET\|DATABASE_URL\|throw\|Missing" \
  "server/config.ts has startup env validation" \
  "server/config.ts missing startup env validation guard"

